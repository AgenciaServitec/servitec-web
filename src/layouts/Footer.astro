---
import ContentWidth from "../components/ContentWidth.astro";
---

<footer class="border-t border-white/10 bg-background py-10">
    <ContentWidth>
        <div class="px-6 text-sm">
            <div class="flex flex-col gap-6 md:flex-row md:justify-between">
                <div>
                    <p class="font-semibold text-foreground">
                        Servitec Peru Group E.I.R.L.
                    </p>
                    <p class="mt-1 text-muted">
                        RUC: 20604141240
                    </p>
                </div>

                <div class="flex flex-col gap-2 text-muted">
                    <a
                            href="https://soporte.servitecperu.com"
                            class="transition hover:text-foreground"
                    >
                        Soporte técnico y hardware
                    </a>
                    <a
                            href="https://software.servitecperu.com"
                            class="transition hover:text-foreground"
                    >
                        Desarrollo de software
                    </a>
                </div>

                <div class="text-muted">
                    <p>Horario de atención:</p>
                    <p class="mt-1">Lunes a viernes · 9:00 a.m. – 7:00 p.m.</p>
                    <p class="mt-2">contacto@servitecperu.com</p>
                </div>
            </div>

            <p class="text-xs text-foreground/40">
                Operamos en todo el Perú 🇵🇪
            </p>

            <div class="mt-8 border-t border-white/10 pt-4 text-center text-xs text-muted">
                © {new Date().getFullYear()} Servitec Perú Group. Todos los derechos reservados.
            </div>
        </div>
    </ContentWidth>
</footer>
