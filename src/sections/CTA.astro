---
import ContentWidth from "../components/ContentWidth.astro";
---

<section class="py-20">
    <ContentWidth>
        <div
                class="relative overflow-hidden rounded-3xl border border-white/10 bg-surface/50 p-10 text-center shadow-elevated"
                data-cta
        >
            <!-- Glow sutil -->
            <div class="pointer-events-none absolute inset-0">
                <div class="absolute -top-24 left-1/2 h-72 w-[38rem] -translate-x-1/2 rounded-full bg-primary/15 blur-3xl"></div>
                <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/0 to-background/30"></div>
            </div>

            <div class="relative">
                <h3 class="text-2xl font-semibold text-foreground md:text-3xl">
                    ¿Necesitas soporte técnico o un sistema para tu empresa?
                </h3>

                <p class="mx-auto mt-4 max-w-2xl text-foreground/80">
                    Escríbenos y recibe asesoría especializada según tu necesidad.
                </p>

                <p class="mt-3 text-sm text-foreground/60">
                    Respuesta rápida • Atención profesional • Soluciones a medida
                </p>

                <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
                    <a
                            href="https://wa.me/51941801827"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-black transition hover:bg-primary-hover"
                    >
                        WhatsApp soporte técnico
                    </a>

                    <a
                            href="https://software.servitecperu.com"
                            class="rounded-xl border border-white/15 px-6 py-3 text-sm font-semibold text-foreground transition hover:border-white/30 hover:bg-white/5"
                    >
                        Cotizar desarrollo de software
                    </a>
                </div>
            </div>
        </div>
    </ContentWidth>
</section>

