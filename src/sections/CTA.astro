---
import ContentWidth from "../components/ContentWidth.astro";
---

<section class="py-20">
    <ContentWidth>
        <div
                class="rounded-3xl border border-white/10 bg-card/40 p-10 text-center transition hover:border-white/20 hover:bg-card/60 hover:shadow-soft"
                data-cta
        >
            <h3 class="text-2xl font-semibold text-foreground md:text-3xl">
                ¿Necesitas soporte técnico o un sistema para tu empresa?
            </h3>

            <p class="mt-2 text-sm text-foreground/60">
                Respuesta rápida • Soporte real • Soluciones a medida
            </p>

            <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
                <a
                        href="https://wa.me/51941801827"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-black transition hover:bg-primary-hover"
                >
                    WhatsApp soporte técnico
                </a>

                <a
                        href="https://software.servitecperu.com"
                        class="rounded-xl border border-white/15 px-6 py-3 text-sm font-semibold text-foreground transition hover:border-white/30 hover:bg-white/5"
                >
                    Cotizar desarrollo de software
                </a>
            </div>
        </div>
    </ContentWidth>

    <script>
        import { pop } from "../lib/motion";

        const box = document.querySelector("[data-cta]");
        if (box) {
            const io = new IntersectionObserver(([entry]) => {
                if (!entry.isIntersecting) return;
                pop(box);
                io.disconnect();
            }, { threshold: 0.2 });

            io.observe(box);
        }
    </script>
</section>
